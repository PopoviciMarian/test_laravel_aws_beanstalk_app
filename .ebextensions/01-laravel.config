option_settings:
  aws:elasticbeanstalk:container:php:phpini:
    document_root: /public
    memory_limit: 256M
    max_execution_time: 60

  aws:elasticbeanstalk:application:
    Application Healthcheck URL: /tasks

  aws:elasticbeanstalk:application:environment:
    APP_ENV: production
    APP_DEBUG: "false"
    LOG_CHANNEL: stderr
